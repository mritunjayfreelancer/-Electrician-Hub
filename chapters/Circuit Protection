            { q: "Fuse ko circuit architecture me hamesha kis wire ke sath lagaya jata hai?", o: ["Neutral wire ke series me", "Phase wire ke series me", "Earth wire ke parallel me", "Neutral ke parallel me"], c: 1 },
            { q: "HRC Fuse ka fixing standardization fusing factor value kitna hota hai?", o: ["1.50", "2.00", "1.11", "0.85"], c: 2 },
            { q: "MCB ke andar normal continuous overload tracking ke liye konse component metal matrix ka upyog hota hai?", o: ["Solenoid Coil", "Bimetallic Strip", "Silver Element", "Quartz Sand Oxide"], c: 1 },
            { q: "Domestic human life shock safety protection ke liye RCCB ki standard nominal sensitivity kitni honi chahiye?", o: ["100 mA", "300 mA", "30 mA", "10 mA"], c: 2 },
            { q: "Short circuit fault ke waqt MCB ka instantaneous operation kis scientific principle par chalta hai?", o: ["Electrostatic Force", "Electromagnetic Solenoid Principle", "Chemical Effect", "Bimetallic Delay Line"], c: 1 },
            { q: "Manually adjustable trip current threshold system inme se kis configuration device me moujood hota hai?", o: ["Normal MCB", "Kit-Kat Fuse", "MCCB", "HRC Fuse"], c: 2 },
            { q: "RCCB ka operational baseline monitoring criteria kis physics fundamental system par completely low-line functional hai?", o: ["Voltage drop detection", "Phase-to-Phase Short Circuit", "Current Imbalance between Phase & Neutral", "High Frequency Noise Filter"], c: 2 },
            { q: "Industrial plant panels me 100A se 1600A current levels ko breaker isolation dene ke liye kya best option hai?", o: ["Normal Domestic MCB", "MCCB", "Rewireable Fuse", "Thermal Overload Relay"], c: 1 },
            { q: "Aakashiye bijli aur high voltage grid switching spikes se costly systems ko safe rakhne ke liye kya lagate hain?", o: ["RCCB", "ELCB", "SPD (Surge Protection Device)", "MPCB"], c: 2 },
            { q: "RCBO switchgear setup component ka absolute complete technical block extension full form kya hai?", o: ["Residual Core Breaker Output", "Residual Current Breaker with Overload", "Rated Current Block Operation", "Rotary Circuit Breaker Operating Panel"], c: 1 },
            { q: "Industrial heavy induction motors ko single phasing (Phase Loss) se bachane ke liye kaun sa breaker lagta hai?", o: ["ACB", "MPCB", "SPD", "RCCB"], c: 1 },
            { q: "Rewireable Kit-Kat fuse ka element banane ke liye tin aur lead alloy ka percentage standard combo kya hai?", o: ["50% Tin, 50% Lead", "63% Tin, 37% Lead", "90% Tin, 10% Lead", "30% Tin, 70% Lead"], c: 1 },
            { q: "Substations aur heavy low tension transformer incomers panel grid loops me konse breaker units feed hote hain?", o: ["MCB", "ACB (Air Circuit Breaker)", "MPCB", "ELCB"], c: 1 },
            { q: "Old model ELCB ka baseline mechanism kis element detection node logic par complete layout frame par tha?", o: ["Residual Current Differential", "Voltage Earth Leakage Fault", "Frequency Curve Overlap", "Power Factor Drop Angle"], c: 1 },
            { q: "HRC Fuse cartridges barrel box matrix me heavy industrial arcs ko instant cooling dene ke liye kya filler rehta hai?", o: ["Normal Compressed Air", "Quartz Pure Sand Powder", "Insulating Oil Grid", "Carbon Dioxide Gas"], c: 1 },
            { q: "Agar koi electrical switchgear circuit load limit se halka sa continuous excess current leta hai to use kya fault kahenge?", o: ["Short Circuit Condition", "Overload Condition", "Earth Open Fault", "Transient Voltage Surge"], c: 1 },
            { q: "SPD device matrix block ke andar dynamic internal core resistance change karne ke liye kya electronic element primary hai?", o: ["Bipolar Transistor", "MOV (Metal Oxide Varistor)", "Zener Power Diode", "Schottky Relay Bridge"], c: 1 },
            { q: "Inme se konse switchgear circuit protection grid system ko backup manual resets ki absolute requirement nahi hoti?", o: ["HRC Fuse Replacement", "Kit-Kat Tar Rewiring", "MCB Reset Switching", "Option A aur B dono"], c: 2 },
            { q: "RCCB installation wiring standard ke anusaar ground safety parameters loop check bypass node kahan implement hona anivarya hai?", o: ["Load distribution endpoints", "Main Income Grid before line splitting", "Sub-panel internal isolation links", "Neutral line direct ground connector"], c: 1 },
            { q: "Switchgear operations framework parameters me Short Circuit Interrupting capacity standard structural unit parameter kya hai?", o: ["Kilo-Watts (kW)", "Kilo-Amperes (kA)", "Kilo-Volt-Amperes (kVA)", "Ohms Metric Line"], c: 1 }
        ];

        // Compile CBT Dynamic Layout Grid
        const rootNode = document.getElementById("mcqDynamicRoot");
        let htmlBuffer = "";

        mcqPool.forEach((item, index) => {
            let num = index + 1;
            htmlBuffer += `
                <div class="mcq-card">
                    <div style="font-weight:600; color:#0f172a; margin-bottom:8px;">Q${num}. ${item.q}</div>
                    <div class="mcq-opt-list">
            `;
            item.o.forEach((opt, optIdx) => {
                htmlBuffer += `
                    <button class="mcq-option-btn" onclick="validateOption(this, ${optIdx === item.c})">
                        ${opt}
                    </button>
                `;
            });
            htmlBuffer += `</div></div>`;
        });
        rootNode.innerHTML = htmlBuffer;

        function validateOption(btn, isCorrect) {
            const parentBlock = btn.parentElement;
            const buttons = parentBlock.querySelectorAll(".mcq-option-btn");
            buttons.forEach(b => b.disabled = true);
            if (isCorrect) {
                btn.classList.add("correct-ans");
            } else {
                btn.classList.add("wrong-ans");
            }
        }

        /* --- Secure Verification 3-MCQ Random Gate Logic --- */
        let gateQuestions = [];
        let currentGateIndex = 0;
        let correctAnswersCount = 0;

        function initiatePdfQuizGate() {
            const scrambled = [...mcqPool].sort(() => 0.5 - Math.random());
            gateQuestions = scrambled.slice(0, 3);
            currentGateIndex = 0;
            correctAnswersCount = 0;
            document.getElementById("pdfQuizModal").style.display = "flex";
            renderGateStep();
        }

        function closePdfModal() {
            document.getElementById("pdfQuizModal").style.display = "none";
        }

        function renderGateStep() {
            const targetContentBox = document.getElementById("quizModalContent");

            if (currentGateIndex >= 3) {
                if (correctAnswersCount === 3) {
                    targetContentBox.innerHTML = `
                        <div style="text-align:center; padding: 20px 0;">
                            <div style="font-size: 50px; margin-bottom: 10px;">🎉</div>
                            <h4 style="color: #15803d; margin: 0 0 10px 0;">Verification Complete!</h4>
                            <p style="color: #475569; font-size: 14px;">Aapka print configuration modal setup securely ready hai...</p>
                        </div>
                    `;
                    setTimeout(() => {
                        closePdfModal();
                        window.print();
                    }, 1500);
                } else {
                    targetContentBox.innerHTML = `
                        <div style="text-align:center; padding: 20px 0;">
                            <div style="font-size: 50px; margin-bottom: 10px;">❌</div>
                            <h4 style="color: #b91c1c; margin: 0 0 10px 0;">Verification Error!</h4>
                            <p style="color: #475569; font-size: 14px; margin-bottom: 20px;">PDF clear output bypass ke liye sabhi 3 verification answers ka correct hona zaruri hai.</p>
                            <button class="btn-action btn-next-module" onclick="initiatePdfQuizGate()">Try Again ↻</button>
                        </div>
                    `;
                }
                return;
            }

            const currentObj = gateQuestions[currentGateIndex];
            let modalHtml = `
                <div style="font-size:12px; color:#64748b; margin-bottom:10px; font-weight:700;">GATE LOCK STATE SAWAl ${currentGateIndex + 1} OF 3</div>
                <div style="font-weight:600; color:#0f172a; margin-bottom:15px;">${currentObj.q}</div>
                <div class="mcq-opt-list">
            `;

            currentObj.o.forEach((optText, optIdx) => {
                modalHtml += `
                    <button class="mcq-option-btn" onclick="checkGateSelection(this, ${optIdx === currentObj.c})">
                        ${optText}
                    </button>
                `;
            });
            modalHtml += `</div>`;
            targetContentBox.innerHTML = modalHtml;
        }

        function checkGateSelection(element, isRight) {
            const listContainer = element.parentElement;
            const groupButtons = listContainer.querySelectorAll(".mcq-option-btn");
            groupButtons.forEach(btn => btn.disabled = true);

            if (isRight) {
                element.classList.add("correct-ans");
                correctAnswersCount++;
            } else {
                element.classList.add("wrong-ans");
            }

            setTimeout(() => {
                currentGateIndex++;
                renderGateStep();
            }, 1000);
        }
    </script>
